# Copy to .env and fill in your values.
# .env is gitignored; .env.example is committed as documentation.

# Stats NZ Open Data API — register at https://api.stats.govt.nz to get a key.
STATS_NZ_API_KEY=
STATS_NZ_BASE_URL=https://api.stats.govt.nz

# data.govt.nz CKAN API — public, no auth needed. Override only if mirroring elsewhere.
CKAN_BASE_URL=https://catalogue.data.govt.nz

# Stats NZ public site — used by Playwright UI tests.
STATSNZ_SITE_URL=https://www.stats.govt.nz
